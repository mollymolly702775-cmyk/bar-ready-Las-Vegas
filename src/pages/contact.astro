---
import BaseLayout from '../layouts/BaseLayout.astro';
import styles from './Contact.module.css';
---

<BaseLayout
  title="Contact — Bar Ready LV | Free Consultation"
  description="Contact Bar Ready LV to book a free consultation or schedule your Mock Health and Safety Inspection in Las Vegas."
  canonical="https://barreadylv.com/contact"
>
  <main>
    {/* HERO BANNER */}
    <section class={styles.heroBanner}>
      <div class={styles.heroBannerContent}>
        <h1 class={styles.heroBannerTitle}>Let's Talk</h1>
        <p class={styles.heroBannerSub}>
          We're here to help your bar stay ahead of every inspection.
        </p>
      </div>
    </section>

    {/* CONTACT SECTION */}
    <section class={styles.contactSection}>
      <div class={styles.contactContainer}>
        <div class={`${styles.contactLeft} fade-in`}>
          <p class={styles.introText}>
            We treat every bar owner as a partner — not just a client. Whether you run a single neighborhood bar or manage a portfolio of Las Vegas venues, we're ready to help you protect what you've built.
          </p>

          <div class={styles.infoList}>
            <div class={styles.infoItem}>
              <div class={styles.infoIcon}>📍</div>
              <div>
                <div class={styles.infoLabel}>Location</div>
                <div class={styles.infoValue}>Las Vegas, NV</div>
              </div>
            </div>
            <div class={styles.infoItem}>
              <div class={styles.infoIcon}>📞</div>
              <div>
                <div class={styles.infoLabel}>Phone</div>
                <a href="tel:7026596733" class={styles.infoLink}>
                  702-659-6733
                </a>
              </div>
            </div>
          </div>

          <div class={styles.painBox}>
            <div class={styles.painBoxIcon}>💡</div>
            <p class={styles.painBoxText}>
              Don't wait for a real inspector to find the problems. Let Bar Ready LV find them first.
            </p>
          </div>

          <div class={styles.plansPreview}>
            <div class={styles.planItem}>
              <span class={styles.planItemLabel}>Monthly Plan</span>
              <span class={styles.planItemPrice}>$350/month</span>
            </div>
            <div class={styles.planItem}>
              <span class={styles.planItemLabel}>Annual Plan</span>
              <span class={styles.planItemPrice}>$3,900/year</span>
            </div>
          </div>
        </div>

        <div class={`${styles.contactRight} fade-in`} style="transition-delay: 100ms">
          <div style="display:flex;justify-content:center;">
            <div
              class="calendly-inline-widget"
              data-url="https://calendly.com/lgdllc1/30min"
              style="min-width:320px;height:700px;width:100%;"
            ></div>
          </div>
          <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async is:inline></script>
        </div>
      </div>
    </section>
  </main>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(el => {
        if (el.isIntersecting) el.target.classList.add('visible');
      });
    }, { threshold: 0.15 });
    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
  </script>
</BaseLayout>
