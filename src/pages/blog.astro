---
import BaseLayout from '../layouts/BaseLayout.astro';
import styles from './Blog.module.css';

const posts = [
  {
    category: 'Compliance',
    title: '5 Health Code Violations Las Vegas Bars Miss Most Often',
    excerpt: 'From improper food storage to overlooked sanitization logs, these are the violations that catch bar owners off guard — and how a Mock Health and Safety Inspection can help you catch them first.',
    gradient: 'linear-gradient(135deg, #061b2d 0%, #0d4a3a 100%)'
  },
  {
    category: 'Tips',
    title: 'What to Expect During a Real Health Inspection',
    excerpt: "Understanding exactly what health inspectors look for puts you in a position to proactively address issues. Here's a breakdown of the real inspection process in Nevada.",
    gradient: 'linear-gradient(135deg, #0d2f4a 0%, #061b2d 100%)'
  },
  {
    category: 'Industry News',
    title: 'Why Proactive Compliance Protects Your Bottom Line',
    excerpt: "The cost of a failed health inspection extends far beyond the fine itself. We break down the full financial picture — and why prevention is always the smarter investment.",
    gradient: 'linear-gradient(135deg, #061b2d 0%, #0a3352 100%)'
  },
  {
    category: 'Updates',
    title: 'The Real Cost of a Failed Health Inspection',
    excerpt: "From temporary closure losses to the long-term impact of a bad health rating, this post quantifies what's actually at stake every time a real inspector walks through your door.",
    gradient: 'linear-gradient(135deg, #0d4a3a 0%, #061b2d 100%)'
  }
];
---

<BaseLayout
  title="Blog — Bar Ready LV | Las Vegas Bar Compliance Resources"
  description="Health inspection tips, compliance guides, and industry news for Las Vegas bars and restaurants from Bar Ready LV."
  canonical="https://barreadylv.com/blog"
>
  <main>
    {/* HERO BANNER */}
    <section class={styles.heroBanner}>
      <div class={styles.heroBannerContent}>
        <h1 class={styles.heroBannerTitle}>Blog &amp; Resources</h1>
        <p class={styles.heroBannerSub}>
          Compliance tips, industry insights, and updates from the Bar Ready LV team.
        </p>
      </div>
    </section>

    {/* BLOG GRID */}
    <section class={styles.blogSection}>
      <div class={styles.blogContainer}>
        <div class={styles.blogGrid}>
          {posts.map((post, i) => (
            <div
              class={`${styles.blogCard} fade-in`}
              style={`transition-delay: ${i * 80}ms`}
            >
              <div class={styles.cardImage} style={`background: ${post.gradient}`}>
                <div class={styles.cardImageOverlay}></div>
              </div>
              <div class={styles.cardBody}>
                <span class={styles.cardCategory}>{post.category}</span>
                <h2 class={styles.cardTitle}>{post.title}</h2>
                <p class={styles.cardExcerpt}>{post.excerpt}</p>
                <button class={styles.cardLink}>Read More →</button>
              </div>
            </div>
          ))}
        </div>

        <div class={`${styles.comingSoon} fade-in`}>
          <div class={styles.comingSoonIcon}>✍️</div>
          <h3 class={styles.comingSoonTitle}>More Posts Coming Soon</h3>
          <p class={styles.comingSoonText}>
            We're regularly publishing compliance tips, industry insights, and Las Vegas hospitality news. Check back often — or reach out to us directly with questions.
          </p>
        </div>
      </div>
    </section>
  </main>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(el => {
        if (el.isIntersecting) el.target.classList.add('visible');
      });
    }, { threshold: 0.15 });
    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
  </script>
</BaseLayout>
