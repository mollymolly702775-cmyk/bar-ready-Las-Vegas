---
import BaseLayout from '../layouts/BaseLayout.astro';
import styles from './Pricing.module.css';
---

<BaseLayout
  title="Pricing — Bar Ready LV | Inspection Plans Las Vegas"
  description="Flat-rate pricing for Mock Health and Safety Inspections. Monthly at $350/month or Annual at $3,900/year. Consultations always free."
  canonical="https://barreadylv.com/pricing"
>
  <main>

    {/* ── SECTION A — Hero (Split Comparison) ── */}
    <section class={styles.heroSection}>

      {/* Decorative LV atmosphere text */}
      <span class={styles.decoLasVegas} aria-hidden="true">LAS VEGAS</span>
      <span class={styles.decoBarReady} aria-hidden="true">BAR READY</span>

      <div class={styles.heroInner}>

        {/* Top label */}
        <p class={styles.heroLabel}>MOCK HEALTH &amp; SAFETY INSPECTIONS — LAS VEGAS</p>

        {/* Main headline */}
        <h1 class={styles.heroHeadline}>The Cost of Not Being Ready.</h1>
        <p class={styles.heroSubline}>vs. The Price of Peace of Mind.</p>

        {/* Split comparison cards */}
        <div class={styles.splitGrid}>

          {/* LEFT CARD — Red / Without */}
          <div class={styles.cardBad}>
            <span class={styles.badgeBad}>WITHOUT BAR READY LV</span>
            <h2 class={styles.splitCardHeadline}>Flying Blind.</h2>
            <ul class={styles.splitList}>
              <li class={styles.splitItem}>
                <span class={styles.iconBad}>✕</span>
                <span>Surprise closure — doors shut, revenue gone overnight</span>
              </li>
              <li class={styles.splitItem}>
                <span class={styles.iconBad}>✕</span>
                <span>Fines stacking up from violations you didn't know existed</span>
              </li>
              <li class={styles.splitItem}>
                <span class={styles.iconBad}>✕</span>
                <span>Public health score tanks on Yelp — customers go elsewhere</span>
              </li>
              <li class={styles.splitItem}>
                <span class={styles.iconBad}>✕</span>
                <span>Staff scrambling during a real inspection with no preparation</span>
              </li>
              <li class={styles.splitItem}>
                <span class={styles.iconBad}>✕</span>
                <span>License at risk from repeated or critical violations</span>
              </li>
            </ul>
            <div class={styles.cardDividerBad}></div>
          </div>

          {/* RIGHT CARD — Green / With */}
          <div class={styles.cardGood}>
            <span class={styles.badgeGood}>WITH BAR READY LV</span>
            <h2 class={styles.splitCardHeadline}>Always Ready.</h2>
            <ul class={styles.splitList}>
              <li class={styles.splitItem}>
                <span class={styles.iconGood}>✓</span>
                <span>Mock inspections catch violations before the real inspector does</span>
              </li>
              <li class={styles.splitItem}>
                <span class={styles.iconGood}>✓</span>
                <span>Zero surprise closures — our clients stay open and operating</span>
              </li>
              <li class={styles.splitItem}>
                <span class={styles.iconGood}>✓</span>
                <span>Clean public health score protects your reputation on Yelp</span>
              </li>
              <li class={styles.splitItem}>
                <span class={styles.iconGood}>✓</span>
                <span>Staff trained and confident — no panic when inspectors arrive</span>
              </li>
              <li class={styles.splitItem}>
                <span class={styles.iconGood}>✓</span>
                <span>Full Inspection Results Report delivered within 1–2 business days</span>
              </li>
            </ul>
            <div class={styles.cardDividerGood}></div>
          </div>

        </div>{/* /splitGrid */}

        {/* Pricing teaser */}
        <p class={styles.pricingTeaser}>PLANS STARTING AT $350/MONTH · ANNUAL PLAN $3,900/YEAR</p>

        {/* Free consultation strip */}
        <div class={styles.consultStrip}>
          <div class={styles.consultStripText}>
            <p class={styles.consultStripHeadline}>Consultations are always free.</p>
            <p class={styles.consultStripSub}>We'll tailor the right plan for your bar.</p>
          </div>
          <a href="/contact" class={styles.consultStripBtn}>Schedule a Free Consultation</a>
        </div>

      </div>{/* /heroInner */}
    </section>

    {/* ── SECTION C — Pricing Cards ── */}
    <section class={styles.cardsSection}>
      <div class={styles.cardsInner}>
        <div class={styles.cardsGrid}>

          {/* Card 1 — Monthly */}
          <div class={styles.card}>
            <div class={styles.cardPlanLabel}>Monthly Plan</div>
            <div class={styles.cardPrice}>
              <span class={styles.cardPriceNum}>$350</span>
              <span class={styles.cardPricePer}>/month</span>
            </div>
            <p class={styles.cardDesc}>
              One Mock Health and Safety Inspection per month for a single bar location.
            </p>
            <ul class={styles.cardFeatures}>
              <li class={styles.cardFeature}>
                <span class={styles.check}>✓</span>
                One inspection per month
              </li>
              <li class={styles.cardFeature}>
                <span class={styles.check}>✓</span>
                Single bar location
              </li>
              <li class={styles.cardFeature}>
                <span class={styles.check}>✓</span>
                Inspection Results Report
              </li>
              <li class={styles.cardFeature}>
                <span class={styles.check}>✓</span>
                Email delivery in 1–2 business days
              </li>
            </ul>
            <a href="/contact" class={styles.cardBtnNavy}>Get Started</a>
          </div>

          {/* Card 2 — Annual */}
          <div class={styles.cardFeatured}>
            <div class={styles.bestValueBadge}>Best Value</div>
            <div class={styles.cardPlanLabel}>Annual Plan</div>
            <div class={styles.cardPrice}>
              <span class={styles.cardPriceNum}>$3,900</span>
              <span class={styles.cardPricePer}>one-time</span>
            </div>
            <p class={styles.cardDesc}>
              Full year of Mock Health and Safety Inspections. One upfront payment, maximum peace of mind.
            </p>
            <ul class={styles.cardFeatures}>
              <li class={styles.cardFeature}>
                <span class={styles.check}>✓</span>
                12 inspections per year
              </li>
              <li class={styles.cardFeature}>
                <span class={styles.check}>✓</span>
                Single bar location
              </li>
              <li class={styles.cardFeature}>
                <span class={styles.check}>✓</span>
                Inspection Results Reports
              </li>
              <li class={styles.cardFeature}>
                <span class={styles.check}>✓</span>
                Save $300 vs monthly
              </li>
            </ul>
            <a href="/contact" class={styles.cardBtnGreen}>Get Started</a>
          </div>

        </div>
      </div>
    </section>

    {/* ── SECTION D — Help Choosing ── */}
    <section class={styles.helpSection}>
      <div class={styles.helpInner}>
        <h2 class={styles.helpHeadline}>Not sure which plan is right for you?</h2>
        <p class={styles.helpBody}>
          Every bar is different. We're happy to talk through your situation and recommend the best fit. Reach out — consultations are always free.
        </p>
        <a href="/contact" class={styles.helpLink}>Contact us →</a>
      </div>
    </section>

  </main>
</BaseLayout>
